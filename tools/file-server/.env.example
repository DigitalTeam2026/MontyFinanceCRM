# Copy this file to ".env" and fill in the values.

# Same Supabase project the CRM uses. Find these in the project root .env
# (VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY) or in the Supabase dashboard.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Service-role key (Supabase dashboard → Project Settings → API). REQUIRED only for
# S3 / SharePoint, because reading their credentials from Vault needs service_role.
# Local / NAS storage works without it. Keep this key secret — never ship it to a browser.
SUPABASE_SERVICE_ROLE_KEY=

# Port the file server listens on. The frontend defaults to this value.
PORT=4000

# Comma-separated list of browser origins allowed to call the server (CORS).
# Add your Vite dev origin. Example for the default Vite port:
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Max upload size in megabytes.
MAX_UPLOAD_MB=100
