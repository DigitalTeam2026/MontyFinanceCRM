# Copy this file to ".env" and adjust the values.

# The local CRM API (server/index.js) — SAME value the frontend uses as VITE_API_URL.
# The file server delegates auth + config lookups to this API; there is NO Supabase.
# Use localhost when the file server runs on the same machine as the API.
API_URL=http://localhost:3001

# Port the file server listens on. The frontend defaults to this value
# (override in the project root .env with VITE_FILE_SERVER_URL if you change it).
PORT=4000

# Comma-separated list of browser origins allowed to call the server (CORS).
# Add your Vite dev origin(s).
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://172.16.78.27:5173

# Max upload size in megabytes.
MAX_UPLOAD_MB=100
